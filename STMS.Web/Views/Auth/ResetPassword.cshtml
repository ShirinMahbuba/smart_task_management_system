@model STMS.Models.PasswordResetModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>STMS - Reset Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .reset-card {
            background: rgba(255,255,255,0.05); backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.15); border-radius: 20px;
            padding: 40px; width: 100%; max-width: 440px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }
        .logo {
            width: 60px; height: 60px;
            background: linear-gradient(135deg, #f39c12, #e67e22);
            border-radius: 14px; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px; font-size: 26px; color: white;
        }
        .page-title { color: #fff; font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 4px; }
        .page-subtitle { color: rgba(255,255,255,0.45); text-align: center; font-size: 0.85rem; margin-bottom: 24px; }
        .form-label { color: rgba(255,255,255,0.75); font-size: 0.83rem; font-weight: 500; margin-bottom: 5px; }
        .form-control {
            background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px; color: #fff; padding: 11px 15px; transition: all 0.3s;
        }
        .form-control:focus {
            background: rgba(255,255,255,0.12); border-color: #f39c12;
            box-shadow: 0 0 0 3px rgba(243,156,18,0.2); color: #fff;
        }
        .form-control::placeholder { color: rgba(255,255,255,0.25); }
        .btn-reset {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            border: none; border-radius: 10px; color: white; font-weight: 600;
            padding: 12px; width: 100%; transition: all 0.3s; margin-top: 6px;
        }
        .btn-reset:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(243,156,18,0.4); color: white; }
        .divider { border-color: rgba(255,255,255,0.1); margin: 20px 0; }
        .footer-links { text-align: center; }
        .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
        .footer-links a:hover { color: #f39c12; }
        .text-danger { font-size: 0.78rem; color: #ff8fa3 !important; }
        .alert-danger { background: rgba(233,69,96,0.15); border: 1px solid rgba(233,69,96,0.4); border-radius: 10px; color: #ff8fa3; font-size: 0.88rem; }
        .copyright { color: rgba(255,255,255,0.2); font-size: 0.75rem; text-align: center; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="reset-card">
        <div class="logo"><i class="bi bi-key-fill"></i></div>
        <div class="page-title">Reset Password</div>
        <div class="page-subtitle">Enter your email and set a new password</div>

        @if (string.IsNullOrEmpty(ViewBag.Error) == false)
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Your registered email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"><i class="bi bi-lock me-1"></i>New Password</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="Min. 6 characters" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"><i class="bi bi-lock-fill me-1"></i>Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Re-enter new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-reset">
                <i class="bi bi-arrow-repeat me-2"></i>Reset Password
            </button>
        </form>

        <hr class="divider" />
        <div class="footer-links">
            <a asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
        <div class="copyright">&copy; 2026 STMS. All rights reserved.</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
