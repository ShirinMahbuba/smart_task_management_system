@model STMS.Models.PasswordResetModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>STMS - Reset Password</title>
     <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.3/cyborg/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body class="bg-black min-vh-100 d-flex align-items-center justify-content-center">

    <div class="card bg-dark border-secondary p-4 w-100" style="max-width: 440px; border-radius: 15px;">
        <div class="card-body">
            
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-warning text-dark rounded-3 mb-2" style="width: 56px; height: 56px; font-size: 24px;">
                    <i class="bi bi-key-fill"></i>
                </div>
                <h2 class="card-title text-white fw-bold mb-1">Reset Password</h2>
                <p class="text-muted small">Smart Task Management System</p>
            </div>

            @if (string.IsNullOrEmpty(ViewBag.Error) == false)
            {
                <div class="alert alert-dismissible alert-danger mb-3">
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="ResetPassword" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label text-light fw-medium small mb-1">
                        <i class="bi bi-envelope me-1"></i>Email
                    </label>
                    <input asp-for="Email" class="form-control bg-black text-white border-secondary" placeholder="Your registered email" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewPassword" class="form-label text-light fw-medium small mb-1">
                        <i class="bi bi-lock me-1"></i>New Password
                    </label>
                    <input asp-for="NewPassword" class="form-control bg-black text-white border-secondary" type="password" placeholder="Min. 6 characters" />
                    <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-light fw-medium small mb-1">
                        <i class="bi bi-lock-fill me-1"></i>Confirm Password
                    </label>
                    <input asp-for="ConfirmPassword" class="form-control bg-black text-white border-secondary" type="password" placeholder="Re-enter new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold text-dark">
                    <i class="bi bi-arrow-repeat me-2"></i>Reset Password
                </button>
            </form>

            <hr class="border-secondary my-4" />

            <div class="text-center small">
                <a asp-action="Login" class="text-info text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>
            
            <div class="text-center text-muted mt-4" style="font-size: 0.75rem;">
                &copy; 2026 STMS. All rights reserved.
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>