@model STMS.Models.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>STMS Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }
        .login-logo {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #e94560, #0f3460);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
            font-size: 28px; color: white;
        }
        .login-title { color: #fff; font-size: 1.6rem; font-weight: 700; text-align: center; margin-bottom: 4px; }
        .login-subtitle { color: rgba(255,255,255,0.5); text-align: center; font-size: 0.9rem; margin-bottom: 28px; }
        .form-label { color: rgba(255,255,255,0.8); font-size: 0.85rem; font-weight: 500; }
        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px; color: #fff;
            padding: 12px 16px; transition: all 0.3s;
        }
        .form-control:focus {
            background: rgba(255,255,255,0.12);
            border-color: #e94560;
            box-shadow: 0 0 0 3px rgba(233,69,96,0.2); color: #fff;
        }
        .form-control::placeholder { color: rgba(255,255,255,0.3); }
        .btn-login {
            background: linear-gradient(135deg, #e94560, #c0392b);
            border: none; border-radius: 10px;
            color: white; font-weight: 600; padding: 12px;
            width: 100%; transition: all 0.3s; margin-top: 8px;
        }
        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(233,69,96,0.4); color: white;
        }
        .divider { border-color: rgba(255,255,255,0.1); margin: 24px 0; }
        .footer-links { text-align: center; }
        .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
        .footer-links a:hover { color: #e94560; }
        .footer-links .sep { color: rgba(255,255,255,0.2); margin: 0 10px; }
        .alert-danger { background: rgba(233,69,96,0.15); border: 1px solid rgba(233,69,96,0.4); border-radius: 10px; color: #ff8fa3; font-size: 0.9rem; }
        .alert-success { background: rgba(40,167,69,0.15); border: 1px solid rgba(40,167,69,0.4); border-radius: 10px; color: #75d7a0; font-size: 0.9rem; }
        .text-danger { font-size: 0.8rem; color: #ff8fa3 !important; }
        .copyright { color: rgba(255,255,255,0.2); font-size: 0.75rem; text-align: center; margin-top: 24px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo"><i class="bi bi-layers-fill"></i></div>
        <div class="login-title">STMS</div>
        <div class="login-subtitle">Sales &amp; Task Management System</div>

        @if (string.IsNullOrEmpty(ViewBag.Error) == false)
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
        }
        @if (string.IsNullOrEmpty(TempData["Success"]?.ToString()) == false)
        {
            <div class="alert alert-success alert-dismissible mb-3">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-login">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </button>
        </form>

        <hr class="divider" />
        <div class="footer-links">
            <a asp-action="Register"><i class="bi bi-person-plus me-1"></i>Register</a>
            <span class="sep">|</span>
            <a asp-action="ResetPassword"><i class="bi bi-key me-1"></i>Forgot Password?</a>
        </div>
        <div class="copyright">&copy; 2026 STMS. All rights reserved.</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
