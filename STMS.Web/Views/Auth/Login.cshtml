@model STMS.Models.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>STMS Login</title>
    <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.0/cyborg/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body class="bg-black min-vh-100 d-flex align-items-center justify-content-center">

    <div class="card bg-dark border-secondary p-4 w-100" style="max-width: 420px; border-radius: 15px;">
        <div class="card-body">
            
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-3 mb-2" style="width: 56px; height: 56px; font-size: 24px;">
                    <i class="bi bi-layers-fill"></i>
                </div>
                <h2 class="card-title text-white fw-bold mb-1">STMS</h2>
                <p class="text-muted small">Smart Task Management System</p>
            </div>

            @if (string.IsNullOrEmpty(ViewBag.Error) == false)
            {
                <div class="alert alert-dismissible alert-danger mb-3">
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
                </div>
            }
            @if (string.IsNullOrEmpty(TempData["Success"]?.ToString()) == false)
            {
                <div class="alert alert-dismissible alert-success mb-3">
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label text-light fw-medium small mb-1">
                        <i class="bi bi-envelope me-1"></i>Email
                    </label>
                    <input asp-for="Email" class="form-control bg-black text-white border-secondary" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Password" class="form-label text-light fw-medium small mb-1">
                        <i class="bi bi-lock me-1"></i>Password
                    </label>
                    <input asp-for="Password" class="form-control bg-black text-white border-secondary" type="password" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login
                </button>
            </form>

            <hr class="border-secondary my-4" />

            <div class="text-center small">
                <a asp-action="Register" class="text-info text-decoration-none me-2">
                    <i class="bi bi-person-plus me-1"></i>Register
                </a>
                <span class="text-muted">|</span>
                <a asp-action="ResetPassword" class="text-info text-decoration-none ms-2">
                    <i class="bi bi-key me-1"></i>Forgot Password?
                </a>
            </div>
            
            <div class="text-center text-muted mt-4" style="font-size: 0.75rem;">
                &copy; 2026 STMS. All rights reserved.
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>