@model List<ViewerTaskListItemModel>
@{
    ViewData["Title"] = "Task Status";
}

@Html.Partial("_Message")

<div class="d-flex justify-content-between align-items-center pt-3">
    <h2 class="text-primary"><i class="bi bi-list-task me-2"></i>Task Status and Details</h2>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>
<hr />

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Task</th>
                    <th>Project</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Due Date</th>
                    <th>Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model)
                {
                    <tr>
                        <td>
                            <strong>@task.Title</strong>
                            <div class="small text-muted">@task.Description</div>
                        </td>
                        <td>@task.ProjectName</td>
                        <td><span class="badge bg-secondary">@task.Status</span></td>
                        <td><span class="badge bg-info text-dark">@task.Priority</span></td>
                        <td>@task.DueDate?.ToString("dd MMM yyyy")</td>
                        <td>@task.UpdatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-primary" asp-action="TaskDetails" asp-route-id="@task.ID">
                                <i class="bi bi-eye me-1"></i>Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
