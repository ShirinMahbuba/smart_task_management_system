@model ViewerTaskDetailsModel
@{
    ViewData["Title"] = "Task Details";
}

<div class="d-flex justify-content-between align-items-center pt-3">
    <h2 class="text-primary"><i class="bi bi-card-checklist me-2"></i>@Model.Title</h2>
    <a class="btn btn-outline-secondary" asp-action="Tasks"><i class="bi bi-arrow-left me-1"></i>Tasks</a>
</div>
<hr />

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-primary text-white fw-bold">Task Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Project</dt><dd class="col-sm-9">@Model.ProjectName</dd>
                    <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd>
                    <dt class="col-sm-3">Priority</dt><dd class="col-sm-9"><span class="badge bg-info text-dark">@Model.Priority</span></dd>
                    <dt class="col-sm-3">Due Date</dt><dd class="col-sm-9">@Model.DueDate?.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header bg-warning fw-bold">Status History</div>
            <div class="list-group list-group-flush">
                @foreach (var step in Model.Steps)
                {
                    <div class="list-group-item">
                        <strong>@step.Status</strong>
                        <div class="small text-muted">@step.PerformedByName - @step.DateTime.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-dark text-white fw-bold">Task Comments</div>
            <div class="list-group list-group-flush">
                @foreach (var comment in Model.Comments)
                {
                    <div class="list-group-item">
                        <div>@comment.CommentText</div>
                        <div class="small text-muted">@comment.UserName - @comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header bg-info text-dark fw-bold">Attachments</div>
            <div class="list-group list-group-flush">
                @foreach (var file in Model.Attachments)
                {
                    <div class="list-group-item">
                        <strong>@file.FileName</strong>
                        <div class="small text-muted">@file.UploadedByName - @file.UpdatedAt.ToString("dd MMM yyyy")</div>
                        @if (!string.IsNullOrWhiteSpace(file.FilePath))
                        {
                            <div class="small">@file.FilePath</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
