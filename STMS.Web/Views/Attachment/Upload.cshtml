@model STMS.Entities.Attachment

@Html.Partial("_Message")

<div class="container border mt-4 p-4">
    <div class="row">
        <div class="col-12">
            <h2>Upload Attachment</h2>
        </div>
        <hr />
    </div>

    <form method="post" enctype="multipart/form-data" action="#">
        <input type="hidden" asp-for="ID" />
        <input type="hidden" asp-for="TaskID" />
        <input type="hidden" asp-for="UploadedBy" value="1" />
        <input type="hidden" asp-for="UpdatedBy" value="1" />

        <div class="row">
            <label class="form-label">Select File</label>
            <input type="file"
                   name="file"
                   class="form-control" />
        </div>

        <div class="row mt-3">
            <div class="col-6">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-upload"></i>&nbsp;Upload
                </button>
                &nbsp;
                <a asp-action="Index"
                   asp-controller="Attachment"
                   asp-route-taskId="@Model.TaskID"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left-circle-fill"></i>&nbsp;Back To List
                </a>
            </div>
        </div>
    </form>
</div>