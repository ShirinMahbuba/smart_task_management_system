@model List<STMS.Entities.Attachment>

@Html.Partial("_Message")

@* --- Header Section --- *@

<div class="row pt-4">
    <div class="col-6">
        <h2 class="text-primary">Task Attachments</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-warning"
           asp-action="Upload"
           asp-controller="Attachment"
           asp-route-taskId="@ViewBag.TaskId">
            <i class="bi bi-upload"></i>&nbsp; Upload File
        </a>
    </div>
</div>

<hr />

@* --- Table Section --- *@

<div class="row pt-2">
    <div class="col-12">
        <table class="table table-bordered table-hover">
            <thead>
                <tr class="table-primary">
                    <th>Ref</th>
                    <th>File Name</th>
                    <th>Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td width="5%">@item.ID</td>
                        <td width="55%">
                            <a href="@item.FilePath" target="_blank">
                                <i class="bi bi-file-earmark"></i>
                                @item.FileName
                            </a>
                        </td>
                        <td width="20%">@item.UpdatedAt?.ToShortDateString()</td>
                        <td class="text-center" width="20%">
                            <div class="btn-group" role="group">
                                <a asp-action="Delete"
                                   asp-controller="Attachment"
                                   asp-route-dataId="@item.ID"
                                   asp-route-taskId="@item.TaskID"
                                   class="btn btn-danger mx-1"
                                   onclick="return confirm('Are you sure?')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>