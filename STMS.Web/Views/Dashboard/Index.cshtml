@{
    ViewData["Title"] = "Employee Dashboard";
}

@Html.Partial("_Message")

@* --- Header Section --- *@

<div class="row pt-4">
    <div class="col-12">
        <h2 class="text-primary">Employee Dashboard</h2>
    </div>
</div>

<hr />

@* --- Stats Cards --- *@

<div class="row pt-2">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-list-task"></i> Total Tasks
                </h5>
                <h2>@ViewBag.TotalTasks</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-hourglass"></i> Pending
                </h5>
                <h2>@ViewBag.PendingTasks</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-arrow-repeat"></i> In Progress
                </h5>
                <h2>@ViewBag.InProgressTasks</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-check-circle"></i> Completed
                </h5>
                <h2>@ViewBag.CompletedTasks</h2>
            </div>
        </div>
    </div>
</div>

@* --- Quick Links --- *@

<div class="row pt-2">
    <div class="col-12">
        <h4>Quick Links</h4>
        <hr />
        <a asp-action="Index"
           asp-controller="Task"
           class="btn btn-primary me-2">
            <i class="bi bi-list-task"></i>&nbsp;My Tasks
        </a>
    </div>
</div>