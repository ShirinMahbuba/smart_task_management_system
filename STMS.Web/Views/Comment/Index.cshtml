@model List<STMS.Entities.Comment>

<partial name="_Message" />

@* --- Header Section --- *@

<div class="row pt-4">
    <div class="col-6">
        <h2 class="text-primary">Task Comments</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-warning"
           asp-action="Detail"
           asp-controller="Comment"
           asp-route-dataId="-1"
           asp-route-taskId="@ViewBag.TaskId">
            <i class="bi bi-plus-circle"></i>&nbsp; Add Comment
        </a>
    </div>
</div>

<hr />

@* --- Table Section --- *@

<div class="row pt-2">
    <div class="col-12">
        <table class="table table-bordered table-hover">
            <thead>
                <tr class="table-primary">
                    <th>Ref</th>
                    <th>Task ID</th>  
                    <th>UserID</th>
                    <th>Comment</th>
                    <th>Created</th>      
                    <th>Updated</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td width="5%">@item.ID</td>
                        <td width="10%">@item.TaskID</td>
                        <td width="10%">@item.UserID</td>
                        <td width="40%">@item.CommentText</td>
                        <td width="15%">@item.CreatedAt.ToShortDateString()</td> 
                        <td width="10%">@item.UpdatedAt.ToShortDateString()</td>
                        <td class="text-center" width="20%">
                            <div class="btn-group" role="group">
                                <a asp-action="Detail"
                                   asp-controller="Comment"
                                   asp-route-dataId="@item.ID"
                                   asp-route-taskId="@item.TaskID"
                                   class="btn btn-primary mx-1">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-action="Delete"
                                   asp-controller="Comment"
                                   asp-route-dataId="@item.ID"
                                   asp-route-taskId="@item.TaskID"
                                   class="btn btn-danger mx-1"
                                   onclick="return confirm('Are you sure?')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>