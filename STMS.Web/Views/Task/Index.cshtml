@model List<STMS.Entities.Task>

@Html.Partial("_Message")

<div class="row pt-4">
    <div class="col-6">
        <h2 class="text-primary">My Assigned Tasks</h2>
    </div>
</div>

<hr />

<div class="row pt-2">
    <div class="col-12">
        <table class="table table-bordered table-hover">
            <thead>
                <tr class="table-primary">
                    <th>Ref</th>
                    <th>Title</th>
                    <th>Priority</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td width="5%">@item.ID</td>
                        <td width="25%">@item.Title</td>
                        <td width="10%">@item.Priority</td>
                        <td width="15%">@(item.DueDate.HasValue ? item.DueDate.Value.ToShortDateString() : "No Date")</td>
                        <td width="15%">
                            @(item.TaskSteps?
                                .OrderByDescending(s => s.DateTime)
                                .FirstOrDefault()?.Status ?? "Pending")
                        </td>
                        <td class="text-center" width="30%">
                            <div class="btn-group" role="group">
                                <a asp-action="Detail"
                                   asp-controller="Task"
                                   asp-route-dataId="@item.ID"
                                   class="btn btn-info mx-1">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Update"
                                   asp-controller="TaskStep"
                                   asp-route-taskId="@item.ID"
                                   class="btn btn-warning mx-1">
                                    <i class="bi bi-arrow-repeat"></i> Status
                                </a>
                                <a asp-action="Index"
                                   asp-controller="Comment"
                                   asp-route-taskId="@item.ID"
                                   class="btn btn-secondary mx-1">
                                    <i class="bi bi-chat"></i> Comments
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>