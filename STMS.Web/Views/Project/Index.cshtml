@model List<STMS.Entities.Project>

@Html.Partial("_Message")

<div class="row pt-4">
    <div class="col-6">
        <h2>Manage projects</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-primary" asp-action="Detail" asp-controller="Project" asp-route-dataId="-1">
            <i class="bi bi-plus-circle-fill"></i> &nbsp; Add new project
        </a>
    </div>
    <hr />
</div>
<div class="row">
    <div class="col-12">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Project Name</th>
                    <th>Description</th>
                    <th>Created By</th>
                    <th>Number of tasks</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())

                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProjectName</td>
                            <td>@item.Description</td>
                            <td>@item.Creator!.Name</td>
                            <td>@item.Tasks.Count</td>
                            <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                            
                            <td>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Detail" asp-controller="Project" asp-route-dataId="@item.ID">
                                    <i class="bi bi-pencil-square"></i> &nbsp; Edit
                                </a>
                                <a class="btn btn-sm btn-outline-danger ms-2" asp-action="Delete" asp-controller="Project" asp-route-dataId="@item.ID" onclick="return confirm('Are you sure you want to delete this project?');">
                                    <i class="bi bi-trash-fill"></i> &nbsp; Delete
                                </a>
                            </td>
                        </tr>
                    }

                }

                else

                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">No projects found.</td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>
