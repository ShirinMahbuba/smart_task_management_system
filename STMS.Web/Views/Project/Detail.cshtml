@model STMS.Entities.Project

@Html.Partial("_Message")

<div class="container border mt-4 p-4">
    <div class="row">
        <div class="col-12">
            @if (Model == null || Model.ID == 0)
            {
                <h2>Add new project</h2>
            }
            else
            {
                <h2>
                    Project # @Model.ID
                </h2>
            }
        </div>
    </div>

    <form method="post" action="#">
        <input type="hidden" asp-for="ID" />
        <input type="hidden" asp-for="CreatedBy" />
        <div class="row mb-3">
            <label asp-for="ProjectName" class="form-label"></label>
            <input asp-for="ProjectName" class="form-control" />
            <span asp-validation-for="ProjectName" class="text-danger"></span>
        </div>

        <div class="row mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
		
        <div class="row mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="row mb-3">
	        <label asp-for="EndDate" class="form-label"></label>
	        <input asp-for="EndDate" type="date" class="form-control" />
	        <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
        @if (Model != null && Model.Tasks.Count > 0)
        {
         <h3>Tasks</h3>
            foreach (var item in Model.Tasks)
        {
        <div class="row mb-3">
        <div class="col-12">
                        <a asp-action="EditTask" asp-controller="TaskManager" asp-route-taskID="@item.ID">
        <i class="bi bi-pencil-square"></i> &nbsp; @item.Title
        </a>
        </div>
        </div>
        }
        }
        @if (Model != null && Model.ID != 0)
        {

            <div class="row mb-3">
                <div class="col-12">
                    <a asp-action="AddTask" asp-controller="TaskManager" asp-route-projectID="@Model?.ID" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> &nbsp; Add Task
                    </a>
                </div>
            </div>
        }
        
		
		

		

        <div>
            <div class="col-6">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy2"></i> &nbsp; Submit
                </button>
                &nbsp;
                <a asp-action="Index" asp-controller="Project">
                    <i class="bi bi-arrow-left-circle-fill"></i> &nbsp; Back to list
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts

{
    @Html.Partial("_ValidationScriptsPartial")
}
